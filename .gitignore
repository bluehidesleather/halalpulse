# HalalPulse local configuration and secrets
/config/config.local.php
/config/sharia-policy.local.json
/config/multibagger-methodology.local.json
# HalalPulse does not use .env, but ignore one if a hosting tool creates it.
.env
.env.*

# Runtime data
/storage/logs/*
!/storage/logs/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/tmp/*
!/storage/tmp/.gitkeep
/storage/documents/*
!/storage/documents/.gitkeep

# Test and coverage output
/.phpunit.cache/
/coverage/

# Editors and operating systems
/.idea/
/.vscode/
.DS_Store
Thumbs.db

# Dependencies, if introduced after architecture review
/vendor/

# Temporary files
*.log
*.tmp
*.swp
